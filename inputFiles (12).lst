<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Admin</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="header">
    <img src="/images/logo.png" class="logo">
    <span class="title">Vel Tech Rangarajan Dr.Sagunthala R&D Institute of Science and Technology</span>
</div>

<h2>Add Event</h2>

<form action="/save" method="post">

<input type="text" name="name" placeholder="Event Name" required>
<input type="text" name="department" placeholder="Department">

<input type="text" name="type" placeholder="Type (Workshop/Seminar)">
<input type="date" name="date">
<input type="text" name="venue" placeholder="Venue">

<input type="number" name="availableSeats" placeholder="Seats" required>

<button type="submit">Save</button>

</form>

<h2>All Events</h2>

<table>
<tr>
    <th>Name</th>
    <th>Dept</th>
    <th>Type</th>
    <th>Date</th>
    <th>Venue</th>
    <th>Seats</th>
    <th>Action</th>
</tr>

<tr th:each="event : ${events}">
    <td th:text="${event.name}"></td>
    <td th:text="${event.department}"></td>
    <td th:text="${event.type}"></td>
    <td th:text="${event.date}"></td>
    <td th:text="${event.venue}"></td>
    <td th:text="${event.availableSeats}"></td>
    <td>
        <a th:href="@{'/delete/' + ${event.id}}">Delete</a>
    </td>
</tr>
</table>

<br>

<a href="/registrations">
    <button>View Registered Students</button>
</a>

</body>
</html>